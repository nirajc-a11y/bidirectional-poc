# LiveKit Cloud
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# LiveKit SIP Trunk (created in LiveKit Cloud dashboard)
LIVEKIT_SIP_TRUNK_ID=

# Groq (free) — get key at console.groq.com
GROQ_API_KEY=

# Deepgram (free $200 credits) — get key at console.deepgram.com
DEEPGRAM_API_KEY=

# Sarvam AI (for Indian English TTS)
SARVAM_API_KEY=

# Voice mode: "indian" (Sarvam bulbul:v3) or "global" (Deepgram aura-2)
VOICE_MODE=indian

# Sarvam speaker (bulbul:v3 options: amelia, sophia, priya, anushka, rupali, niharika, etc.)
SARVAM_SPEAKER=amelia

# Agent Configuration
AGENT_NAME=Sarah
PROVIDER_NAME=ABC Medical Group
